# Nord City — single root .env
# Copy to .env and fill real secrets: cp .env.example .env

# === Telegram Bot ===
BOT_TOKEN=your_bot_token
ADMIN_CHAT_ID=your_admin_chat_id
CHIEF_ENGINEER_CHAT_ID=

# === Database (PostgreSQL) ===
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=nordcity_db
DB_USER=nordcity_app
DB_PASSWORD=change_me

# === Internal Services ===
DATABASE_SERVICE_HOST=127.0.0.1
DATABASE_SERVICE_PORT=8001
DATABASE_SERVICE_HTTP_URL=http://127.0.0.1:8001
DATABASE_SERVICE_TIMEOUT=30

AUDIT_SERVICE_HOST=127.0.0.1
AUDIT_SERVICE_PORT=8005
AUDIT_SERVICE_HTTP_URL=http://127.0.0.1:8005
AUDIT_SERVICE_TIMEOUT=30

BOT_SERVICE_HOST=127.0.0.1
BOT_SERVICE_PORT=8002
BOT_SERVICE_HTTP_URL=http://127.0.0.1:8002
BOT_SERVICE_TIMEOUT=30

STORAGE_SERVICE_HOST=127.0.0.1
STORAGE_SERVICE_PORT=8004
STORAGE_SERVICE_HTTP_URL=http://127.0.0.1:8004
STORAGE_SERVICE_TIMEOUT=30
STORAGE_MAX_UPLOAD_SIZE=26214400

WEB_SERVICE_HOST=127.0.0.1
WEB_SERVICE_PORT=8003

# === Public API / Frontend ===
# These are the canonical public URLs returned to clients and used by the browser.
PUBLIC_API_BASE_URL=https://your-domain.com/api/v1
NEXT_PUBLIC_API_URL=https://your-domain.com/api/v1
SITE_PORT=3000

# === CORS (Web Service) ===
# Comma-separated frontend origins only (not the API origin).
CORS_ORIGINS=https://your-domain.com,http://localhost:3000

# === JWT (Web Service) ===
JWT_SECRET_KEY=change_me
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=30

# === Reverse Proxy / TLS ===
NGINX_DOMAIN=your-domain.com
NGINX_SSL_CERT=/etc/letsencrypt/live/your-domain.com/fullchain.pem
NGINX_SSL_KEY=/etc/letsencrypt/live/your-domain.com/privkey.pem

# === MinIO / S3 backend for storage_service ===
# STORAGE_S3_ENDPOINT is the internal address used by storage_service.
STORAGE_S3_ENDPOINT=127.0.0.1:9000
STORAGE_S3_SECURE=false

# STORAGE_S3_PUBLIC_ENDPOINT is the external host used in presigned upload URLs.
# Use only host[:port]; if you include https:// it will be normalized automatically.
STORAGE_S3_PUBLIC_ENDPOINT=uploads.your-domain.com
STORAGE_S3_PUBLIC_SECURE=true

STORAGE_S3_ACCESS_KEY=change_me
STORAGE_S3_SECRET_KEY=change_me
STORAGE_S3_BUCKET=nord-city-storage
STORAGE_S3_REGION=
STORAGE_S3_PRESIGNED_EXPIRY_SECONDS=900
STORAGE_S3_AUTO_CREATE_BUCKET=true
